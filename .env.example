# Flask
SECRET_KEY=replace-with-your-secret-key
FLASK_DEBUG=true
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# MySQL (XAMPP 預設可用以下值)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=ocu_project
DB_CHARSET=utf8mb4
DB_CONNECT_TIMEOUT=10

# App behavior
FOCUS_ETF_LIMIT=5
RECOMMEND_ETF_LIMIT=6
ONE_YEAR_PERIOD=1y
RECENT_PERIOD=5d
COMPARE_PERIOD=3mo

